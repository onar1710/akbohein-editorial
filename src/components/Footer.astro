---
import { SITE } from '../site';

const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="footer-background">
		<div class="footer-pattern"></div>
	</div>
	<div class="footer-content">
		<div class="footer-main">
			<div class="footer-brand">
				<div class="brand-title">
					<span class="brand-name">{SITE.name}</span>
				</div>
				<p class="brand-description">
					Literature, education, culture and more. Stories and articles that inspire, educate and transform.
				</p>
			</div>

			<div class="footer-sections">
				<div class="footer-section">
					<h3 class="section-title">Explore</h3>
					<nav class="section-links">
						<a href="/literature" class="section-link">Literature</a>
						<a href="/education" class="section-link">Education</a>
						<a href="/culture" class="section-link">Culture</a>
						<a href="/books" class="section-link">Books</a>
					</nav>
				</div>

				<div class="footer-section">
					<h3 class="section-title">Community</h3>
					<nav class="section-links">
						<a href="/society" class="section-link">Society</a>
						<a href="/policy" class="section-link">Policy</a>
					</nav>
				</div>

				<div class="footer-section">
					<h3 class="section-title">Company</h3>
					<nav class="section-links">
						<a href="/about-us" class="section-link">About</a>
						<a href="/testimonials" class="section-link">Testimonials</a>
						<a href="/contact" class="section-link">Contact</a>
					</nav>
				</div>
			</div>
		</div>

		<div class="footer-bottom">
			<div class="footer-legal">
				<span class="copyright">© 2014 {SITE.name}. All rights reserved.</span>
				<nav class="legal-links">
					<a href="/privacy-policy" class="legal-link">Privacy Policy</a>
					<a href="/terms-of-service" class="legal-link">Terms of Service</a>
					<a href="/cookie-policy" class="legal-link">Cookie Policy</a>
					<a href="/disclaimer" class="legal-link">Disclaimer</a>
				</nav>
			</div>
			
			<div class="footer-social">
				<span class="social-text">Follow Us</span>
				<div class="social-links">
					<a href="#" class="social-link" aria-label="Facebook">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
							<path d="M18.9 0H1.1C.5 0 0 .5 0 1.1v17.8c0 .6.5 1.1 1.1 1.1H10v-7.8H7.5V9.1H10V7c0-2.4 1.5-3.7 3.6-3.7 1 0 1.9.1 2.2.1v2.5h-1.5c-1.2 0-1.4.6-1.4 1.4v1.7h2.8l-.4 2.5h-2.4V20h4.8c.6 0 1.1-.5 1.1-1.1V1.1C20 .5 19.5 0 18.9 0z"/>
						</svg>
					</a>
					<a href="#" class="social-link" aria-label="Twitter">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
							<path d="M20 3.924c-.736.326-1.527.546-2.357.645.847-.508 1.498-1.311 1.804-2.27-.793.47-1.67.812-2.606.996C15.092 2.493 14.027 2 12.847 2c-2.266 0-4.103 1.837-4.103 4.103 0 .322.036.635.106.935-3.41-.17-6.434-1.804-8.456-4.287-.353.607-.556 1.312-.556 2.064 0 1.424.724 2.679 1.825 3.415-.672-.021-1.305-.206-1.858-.514v.052c0 1.988 1.414 3.647 3.292 4.023-.344.095-.707.145-1.081.145-.264 0-.521-.026-.771-.074.523 1.632 2.038 2.816 3.833 2.851-1.404 1.1-3.174 1.757-5.096 1.757-.331 0-.658-.019-.98-.057 1.816 1.164 3.973 1.843 6.29 1.843 7.547 0 11.675-6.252 11.675-11.675 0-.178-.004-.355-.012-.531.802-.578 1.497-1.301 2.047-2.123z"/>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		position: relative;
		background: linear-gradient(135deg, #8b0000 0%, #660000 100%);
		color: rgba(255, 255, 255, 0.9);
		margin-top: 120px;
		overflow: hidden;
	}

	.footer-background {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		opacity: 0.1;
		z-index: 0;
	}

	.footer-pattern {
		width: 100%;
		height: 100%;
		background-image: 
			radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.03) 0%, transparent 50%),
			radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.02) 0%, transparent 50%),
			linear-gradient(45deg, transparent 48%, rgba(255, 255, 255, 0.01) 48%, rgba(255, 255, 255, 0.01) 52%, transparent 52%);
		background-size: 800px 800px, 600px 600px, 40px 40px;
		background-position: 0 0, 100% 100%, 0 0, 20px 20px;
	}

	.footer-content {
		position: relative;
		z-index: 1;
		max-width: 1400px;
		margin: 0 auto;
		padding: 80px 24px 40px;
	}

	.footer-main {
		display: grid;
		grid-template-columns: 1fr;
		gap: 60px;
		margin-bottom: 60px;
	}

	@media (min-width: 768px) {
		.footer-main {
			grid-template-columns: 1fr;
			gap: 80px;
		}
	}

	.footer-brand {
		max-width: 500px;
	}

	.brand-title {
		margin-bottom: 20px;
	}

	.brand-name {
		display: block;
		font-family: 'Playfair Display', 'Georgia', serif;
		font-size: clamp(24px, 4vw, 36px);
		font-weight: 900;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: white;
		line-height: 1.1;
		margin-bottom: 4px;
	}

	.brand-subtitle {
		display: block;
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 12px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.6);
		font-weight: 400;
	}

	.brand-description {
		font-family: 'Crimson Text', 'Georgia', serif;
		font-size: 16px;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.7);
		margin: 0;
		font-weight: 400;
	}

	.footer-sections {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 40px;
	}

	@media (min-width: 768px) {
		.footer-sections {
			grid-template-columns: repeat(3, 1fr);
			max-width: 800px;
			margin: 0 auto;
		}
	}

	.footer-section {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.section-title {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: white;
		margin: 0;
	}

	.section-links {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.section-link {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 14px;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		padding-left: 0;
	}

	.section-link::before {
		content: '';
		position: absolute;
		left: -16px;
		top: 50%;
		transform: translateY(-50%);
		width: 4px;
		height: 4px;
		background: rgba(255, 255, 255, 0.3);
		border-radius: 50%;
		opacity: 0;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.section-link:hover {
		color: white;
		padding-left: 8px;
	}

	.section-link:hover::before {
		opacity: 1;
		left: 0;
	}

	.footer-bottom {
		display: flex;
		flex-direction: column;
		gap: 32px;
		padding-top: 40px;
		border-top: 1px solid rgba(255, 255, 255, 0.2);
	}

	.footer-legal {
		display: flex;
		flex-direction: column;
		gap: 16px;
		align-items: flex-start;
	}

	.copyright {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.5);
		font-weight: 400;
	}

	.legal-links {
		display: flex;
		gap: 24px;
		flex-wrap: wrap;
	}

	.legal-link {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		transition: color 0.3s ease;
		font-weight: 400;
	}

	.legal-link:hover {
		color: rgba(255, 255, 255, 0.9);
	}

	.footer-social {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		flex-wrap: wrap;
	}

	.social-text {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.7);
		font-weight: 600;
	}

	.social-links {
		display: flex;
		gap: 16px;
	}

	.social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.social-link:hover {
		background: rgba(255, 255, 255, 0.2);
		color: white;
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.2);
	}

	.social-link svg {
		width: 18px;
		height: 18px;
		transition: transform 0.3s ease;
	}

	.social-link:hover svg {
		transform: scale(1.1);
	}

	@media (min-width: 768px) {
		.footer-content {
			padding: 100px 32px 48px;
		}

		.footer-main {
			grid-template-columns: 2fr 3fr;
			gap: 80px;
		}

		.footer-bottom {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}

		.footer-legal {
			align-items: center;
		}

		.footer-social {
			align-items: center;
		}
	}

	@media (min-width: 1024px) {
		.footer-content {
			padding: 120px 40px 56px;
		}

		.footer-sections {
			gap: 60px;
		}
	}

	@media (min-width: 1400px) {
		.footer-content {
			padding: 140px 40px 64px;
		}
	}
</style>
