---
import { getCollection } from 'astro:content';
import { CATEGORIES, getArticleHref } from '../site';

type Props = {
	currentId: string;
	category: string;
	count?: number;
};

const { currentId, category, count = 4 } = Astro.props as Props;

const hashString = (value: string) => {
	let hash = 5381;
	for (let i = 0; i < value.length; i++) {
		hash = (hash * 33) ^ value.charCodeAt(i);
	}
	return hash >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a = (a + 0x6d2b79f5) >>> 0;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleInPlace = <T,>(arr: T[], rnd: () => number) => {
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rnd() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

const rnd = mulberry32(hashString(`${category}:${currentId}`));

const pool = (await getCollection('articles', (e) => e.data.category === category)).filter((e) => e.id !== currentId);
const withImage = pool.filter((e) => Boolean(e.data.featuredImage ?? e.data.heroImage));
const withoutImage = pool.filter((e) => !Boolean(e.data.featuredImage ?? e.data.heroImage));

shuffleInPlace(withImage, rnd);
shuffleInPlace(withoutImage, rnd);

const selected = withImage.slice(0, count);
if (selected.length < count) selected.push(...withoutImage.slice(0, count - selected.length));

const categoryInfo = CATEGORIES.find((c) => c.slug === category);
---

{selected.length > 0 && (
	<section class="related">
		<h2 class="related-title">Related Articles</h2>
		<div class="related-grid">
			{selected.map((related) => {
				const href = getArticleHref(related as unknown as { id: string; data: { category: string } });
				const image = related.data.featuredImage ?? related.data.heroImage;
				return (
					<article class="related-card">
						<a class="related-link" href={href} aria-label={related.data.title}></a>
						{image && (
							<div class="related-image">
								<img src={image} alt={related.data.title} loading="lazy" />
							</div>
						)}
						<div class="related-content">
							<p class="related-meta">
								{categoryInfo?.label ?? category} ·{' '}
								{related.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
							</p>
							<span class="related-card-title" aria-hidden="true">
								{related.data.title}
							</span>
							{related.data.description && <p class="related-desc">{related.data.description}</p>}
						</div>
					</article>
				);
			})}
		</div>
	</section>
)}

<style>
	.related {
		margin-top: 56px;
		padding-top: 40px;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.related-title {
		font-family: 'Playfair Display', 'Georgia', serif;
		font-size: 28px;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: #1a1a1a;
		margin: 0 0 18px;
	}

	.related-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
	}

	.related-card {
		position: relative;
		background: #fff;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 14px;
		overflow: hidden;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.related-link {
		position: absolute;
		inset: 0;
		z-index: 10;
		display: block;
		border-radius: 14px;
	}

	.related-link:focus-visible {
		outline: 3px solid rgba(139, 0, 0, 0.55);
		outline-offset: 2px;
	}

	.related-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.1);
	}

	.related-image,
	.related-content {
		position: relative;
		z-index: 1;
		pointer-events: none;
	}

	.related-image {
		height: 160px;
		overflow: hidden;
		background: rgba(0, 0, 0, 0.02);
	}

	.related-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.related-card:hover .related-image img {
		transform: scale(1.05);
	}

	.related-content {
		padding: 14px 16px 16px;
	}

	.related-meta {
		margin: 0 0 10px;
		font-size: 12px;
		font-family: 'Inter', sans-serif;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.7);
	}

	.related-card-title {
		font-family: 'Playfair Display', 'Georgia', serif;
		font-weight: 800;
		font-size: 18px;
		line-height: 1.25;
		color: #1a1a1a;
		display: block;
	}

	.related-desc {
		margin: 10px 0 0;
		font-family: 'Crimson Text', 'Georgia', serif;
		font-size: 15px;
		line-height: 1.55;
		color: rgba(0, 0, 0, 0.72);
	}

	@media (min-width: 768px) {
		.related-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 18px;
		}
	}

	@media (min-width: 1024px) {
		.related-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}
</style>

