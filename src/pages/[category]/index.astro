---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES } from '../../site';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	return CATEGORIES.map((c) => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;
const categoryInfo = CATEGORIES.find((c) => c.slug === category);

if (!categoryInfo) {
	throw new Error(`Categoría no válida: ${category}`);
}

const entries = (await getCollection('articles', (e) => e.data.category === categoryInfo.slug)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const getArticleSlug = (entry: (typeof entries)[number]) => {
	const id = entry.id;
	if (typeof id !== 'string') return '';
	const parts = id.replace(/\.(md|mdx)$/, '').split('/');
	return parts.slice(1).join('/');
};
---

<Layout>
	<header class="header">
		<h1>{categoryInfo.label}</h1>
	</header>

	<section class="grid">
		{entries.map((entry) => (
			<article class="card">
				<a
					class="card-link"
					href={`/${categoryInfo.slug}/${getArticleSlug(entry)}`}
					aria-label={entry.data.title}
				></a>
				{entry.data.featuredImage && (
					<div class="card-image">
						<img src={entry.data.featuredImage} alt={entry.data.title} />
					</div>
				)}
				<div class="card-content">
					<p class="meta">{entry.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
					<span class="title" aria-hidden="true">{entry.data.title}</span>
					{entry.data.description && <p class="desc">{entry.data.description}</p>}
					<div class="card-footer">
						<span class="read-more" aria-hidden="true">Read More</span>
					</div>
				</div>
			</article>
		))}
	</section>
</Layout>

<style>
	.header {
		padding: 8px 0 16px;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	h1 {
		font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
		font-size: clamp(32px, 5vw, 48px);
		font-weight: 900;
		letter-spacing: -0.03em;
		margin: 0 0 16px;
		color: #1a1a1a;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 12px;
	}

	.card {
		position: relative;
		background: white;
		border: 1px solid rgba(0, 0, 0, 0.08);
		border-radius: 16px;
		overflow: hidden;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		cursor: pointer;
	}

	.card-link {
		position: absolute;
		inset: 0;
		z-index: 10;
		display: block;
		border-radius: 16px;
	}

	.card-link:focus-visible {
		outline: 3px solid rgba(139, 0, 0, 0.55);
		outline-offset: 2px;
		border-radius: 16px;
	}

	.card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
	}

	.card-image {
		position: relative;
		z-index: 1;
		pointer-events: none;
		width: 100%;
		height: 200px;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.card:hover .card-image img {
		transform: scale(1.05);
	}

	.card-content {
		position: relative;
		z-index: 1;
		pointer-events: none;
		padding: 16px;
	}

	.title {
		text-decoration: none;
		color: #1a1a1a;
		font-weight: 700;
		font-size: 18px;
		font-family: 'Playfair Display', Georgia, serif;
		display: block;
		margin-bottom: 8px;
		line-height: 1.3;
	}

	.desc {
		margin: 8px 0;
		color: rgba(0, 0, 0, 0.72);
		font-size: 14px;
		line-height: 1.5;
	}

	.meta {
		margin: 0 0 10px;
		font-size: 13px;
		color: #1a1a1a;
		font-family: 'Inter', sans-serif;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.card-footer {
		display: flex;
		justify-content: flex-end;
		margin-top: 14px;
		padding-top: 12px;
		border-top: 1px solid rgba(0, 0, 0, 0.06);
	}

	.read-more {
		font-family: 'Inter', sans-serif;
		font-size: 13px;
		font-weight: 800;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #8b0000;
		white-space: nowrap;
	}

	@media (min-width: 860px) {
		.grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
