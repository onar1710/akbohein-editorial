const hashString = (value: string) => {
	let hash = 5381;
	for (let i = 0; i < value.length; i++) {
		hash = (hash * 33) ^ value.charCodeAt(i);
	}
	return hash >>> 0;
};

const mulberry32 = (seed: number) => {
	let a = seed >>> 0;
	return () => {
		a = (a + 0x6d2b79f5) >>> 0;
		let t = a;
		t = Math.imul(t ^ (t >>> 15), t | 1);
		t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
		return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
	};
};

const shuffleInPlace = <T,>(arr: T[], rnd: () => number) => {
	for (let i = arr.length - 1; i > 0; i--) {
		const j = Math.floor(rnd() * (i + 1));
		[arr[i], arr[j]] = [arr[j], arr[i]];
	}
	return arr;
};

export async function getStaticPaths() {
	const entries = await getCollection('articles');

	return entries.map((entry) => ({
		params: {
			category: entry.id.replace(/\.(md|mdx)$/, '').split('/')[0],
			slug: entry.id.replace(/\.(md|mdx)$/, '').split('/').slice(1).join('/'),
		},
		props: { entry },
	}));
}

const { entry } = Astro.props;
const categoryInfo = CATEGORIES.find((c) => c.slug === entry.data.category);
const isBooksCategory = entry.data.category === 'books';

const getArticleSlug = (collectionEntry: { id: string }) => {
	const id = collectionEntry.id;
	const parts = id.replace(/\.(md|mdx)$/, '').split('/');
	return parts.slice(1).join('/');
};

const allEntries = await getCollection('articles');
const otherEntries = allEntries.filter((e) => e.id !== entry.id);
const sameCategoryPool = otherEntries.filter((e) => e.data.category === entry.data.category);

const rng = mulberry32(hashString(typeof entry.id === 'string' ? entry.id : String(entry.data.title)));
const desiredCount = 3 + Math.floor(rng() * 5);
const linkPool = shuffleInPlace([...sameCategoryPool], rng);
const internalLinkEntries = linkPool.slice(0, Math.min(desiredCount, 7, linkPool.length));
type InternalLinkItem = { phrase: string; href: string; title: string };
const internalLinkItems: InternalLinkItem[] = internalLinkEntries.map((linked) => {
	const variation = INTERNAL_LINK_VARIATIONS[Math.floor(rng() * INTERNAL_LINK_VARIATIONS.length)] ?? '';
	const phrase = variation.trim();
	const href = `/${linked.data.category}/${getArticleSlug(linked)}`;
	return { phrase, href, title: linked.data.title };
});
const internalLinkItemsJson = JSON.stringify(internalLinkItems).replace(/</g, '\\u003c');

const relatedEntries = (await getCollection('articles', (e) => e.data.category === entry.data.category))
	.filter((e) => e.id !== entry.id)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const selectedAuthor = (() => {
	const match = entry.data.author ? AUTHORS.find((a) => a.name === entry.data.author) : undefined;
	if (match) return match;
	const idx = hashString(typeof entry.id === 'string' ? entry.id : String(entry.data.title)) % AUTHORS.length;
	return AUTHORS[idx];
})();

const { Content } = await render(entry);
---

<Layout
	title={`${entry.data.title} | Akboheim`}
	description={entry.data.description ?? entry.data.title}
	canonical={`https://akboheim.com/${entry.data.category}/${typeof entry.id === 'string' ? entry.id.replace(/\.(md|mdx)$/, '').split('/').slice(1).join('/') : ''}`}
	author={selectedAuthor.name}
	ogType="article"
	image={entry.data.featuredImage ?? entry.data.heroImage}
	imageAlt={entry.data.title}
	publishedTime={entry.data.date.toISOString()}
	modifiedTime={entry.data.date.toISOString()}
	tags={entry.data.tags}
	section={categoryInfo?.label ?? entry.data.category}
>
	<main class="article-page">
		<div class="article-container">
			<article class="article">
				{entry.data.featuredImage && (
					<div class:list={["featured-image", isBooksCategory ? "featured-image--book" : ""]}>
						<img
							class:list={[isBooksCategory ? "featured-image__img--book" : ""]}
							src={entry.data.featuredImage}
							alt={entry.data.title}
							loading="eager"
						/>
					</div>
				)}
				
				<header class="article-header">
					<div class="article-meta">
						<span class="category">{categoryInfo?.label ?? entry.data.category}</span>
						<span class="separator">·</span>
						<time datetime={entry.data.date.toISOString()}>
							{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</time>
						<>
							<span class="separator">·</span>
							<span class="author">Authors: {selectedAuthor.name}</span>
						</>
					</div>
					<h1 class="article-title">{entry.data.title}</h1>
					{entry.data.description && (
						<p class="article-description">{entry.data.description}</p>
					)}
				</header>

				<div class="article-content">
					<Content />
				</div>

				{internalLinkItems.length > 0 && (
					<>
						<script type="application/json" id="internal-links-data" set:html={internalLinkItemsJson} />
						<script is:inline>
							(() => {
								const dataEl = document.getElementById('internal-links-data');
								const root = document.querySelector('.article-content');
								if (!(dataEl instanceof HTMLScriptElement) || !(root instanceof HTMLElement)) return;

								/** @type {{ phrase: string; href: string; title: string }[]} */
								let items = [];
								try {
									items = JSON.parse(dataEl.textContent || '[]');
								} catch {
									return;
								}

								const paragraphs = Array.from(root.querySelectorAll('p')).filter((p) => {
									if (!(p instanceof HTMLParagraphElement)) return false;
									if (p.classList.contains('internal-link')) return false;
									if (p.querySelector('a')) return true;
									return (p.textContent || '').trim().length > 0;
								});

								const maxLinks = Math.min(items.length, 7);
								if (maxLinks === 0 || paragraphs.length === 0) return;

								const usableLinks = items.slice(0, maxLinks);
								const total = paragraphs.length;
								const usedIndices = new Set();

								for (let i = 0; i < usableLinks.length; i++) {
									const target = Math.floor(((i + 1) * total) / (usableLinks.length + 1));
									let idx = Math.min(Math.max(target, 0), total - 1);
									while (usedIndices.has(idx) && idx < total - 1) idx++;
									while (usedIndices.has(idx) && idx > 0) idx--;
									if (usedIndices.has(idx)) continue;
									usedIndices.add(idx);

									const { phrase, href, title } = usableLinks[i];
									const p = document.createElement('p');
									p.className = 'internal-link';
									p.append(document.createTextNode(phrase ? `${phrase} ` : ''));
									const a = document.createElement('a');
									a.href = href;
									a.textContent = title;
									p.append(a);

									const anchor = paragraphs[idx];
									anchor.insertAdjacentElement('afterend', p);
								}
							})();
						</script>
					</>
				)}

				{relatedEntries.length > 0 && (
					<section class="related">
						<h2 class="related-title">Related Articles</h2>
						<div class="related-grid">
							{relatedEntries.map((related) => (
								<article class="related-card">
									<a
										class="related-link"
										href={`/${related.data.category}/${getArticleSlug(related)}`}
										aria-label={related.data.title}
									></a>
									{related.data.featuredImage && (
										<div class="related-image">
											<img src={related.data.featuredImage} alt={related.data.title} loading="lazy" />
										</div>
									)}
									<div class="related-content">
										<p class="related-meta">
											{related.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
										</p>
										<span class="related-card-title" aria-hidden="true">{related.data.title}</span>
									</div>
								</article>
							))}
						</div>
					</section>
				)}
			</article>
		</div>
	</main>
</Layout>

