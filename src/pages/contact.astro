---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="page-container">
		<div class="page-header">
			<h1>Contact Us</h1>
			<p class="page-subtitle">Get in touch with Akboheim</p>
		</div>

		<div class="page-content">
			<p>
				We welcome your feedback, story ideas, and inquiries. Whether you're a reader, writer, or organization interested in collaborating, we'd love to hear from you.
			</p>

			<div class="contact-grid">
				<div class="contact-info">
					<h2>Contact Information</h2>
					<address class="contact-details">
						<strong>Akboheim</strong><br>
						Miami, Florida<br>
						United States<br><br>
						Email: <a href="mailto:contact@akboheim.com">contact@akboheim.com</a><br>
						Phone: <a href="tel:323-941-4865">323-941-4865</a>
					</address>

					<div class="contact-sections">
						<div class="contact-section">
							<h3>Editorial Submissions</h3>
							<p>
								For article submissions, story pitches, and editorial inquiries, please email us at <a href="mailto:editorial@akboheim.com">editorial@akboheim.com</a>. Include a brief summary of your work and your background.
							</p>
						</div>

						<div class="contact-section">
							<h3>Advertising & Partnerships</h3>
							<p>
								For advertising opportunities, sponsored content, and partnership inquiries, please contact us at <a href="mailto:advertising@akboheim.com">advertising@akboheim.com</a>.
							</p>
						</div>

						<div class="contact-section">
							<h3>General Inquiries</h3>
							<p>
								For all other questions, feedback, or technical issues, please use our general contact email: <a href="mailto:contact@akboheim.com">contact@akboheim.com</a>.
							</p>
						</div>
					</div>
				</div>

				<div class="contact-form-wrapper">
					<h2>Send us a Message</h2>
					<form class="contact-form" action="mailto:contact@akboheim.com" method="post" enctype="text/plain">
						<div class="form-group">
							<label for="name">Name *</label>
							<input type="text" id="name" name="name" required placeholder="Your full name">
						</div>

						<div class="form-group">
							<label for="email">Email *</label>
							<input type="email" id="email" name="email" required placeholder="your.email@example.com">
						</div>

						<div class="form-group">
							<label for="subject">Subject *</label>
							<select id="subject" name="subject" required>
								<option value="">Select a topic</option>
								<option value="general">General Inquiry</option>
								<option value="editorial">Editorial Submission</option>
								<option value="advertising">Advertising/Partnership</option>
								<option value="feedback">Feedback</option>
								<option value="technical">Technical Issue</option>
								<option value="other">Other</option>
							</select>
						</div>

						<div class="form-group">
							<label for="message">Message *</label>
							<textarea id="message" name="message" rows="6" required placeholder="Tell us what's on your mind..."></textarea>
						</div>

						<button type="submit" class="submit-btn">Send Message</button>
					</form>
				</div>
			</div>

			<div class="additional-info">
				<h2>Response Times</h2>
				<p>
					We strive to respond to all inquiries within 2-3 business days. Editorial submissions may take longer to review due to the volume of requests we receive.
				</p>

				<h2>Office Hours</h2>
				<p>
					Monday - Friday: 9:00 AM - 5:00 PM EST<br>
					Weekend: Closed (Email inquiries welcome)
				</p>

				<h2>Follow Us</h2>
				<p>
					Stay connected with Akboheim through social media for updates, announcements, and engaging discussions about literature, culture, and education.
				</p>
				<div class="social-links">
					<a href="#" class="social-link" aria-label="Facebook">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
							<path d="M18.9 0H1.1C.5 0 0 .5 0 1.1v17.8c0 .6.5 1.1 1.1 1.1H10v-7.8H7.5V9.1H10V7c0-2.4 1.5-3.7 3.6-3.7 1 0 1.9.1 2.2.1v2.5h-1.5c-1.2 0-1.4.6-1.4 1.4v1.7h2.8l-.4 2.5h-2.4V20h4.8c.6 0 1.1-.5 1.1-1.1V1.1C20 .5 19.5 0 18.9 0z"/>
						</svg>
					</a>
					<a href="#" class="social-link" aria-label="Twitter">
						<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
							<path d="M20 3.924c-.736.326-1.527.546-2.357.645.847-.508 1.498-1.311 1.804-2.27-.793.47-1.67.812-2.606.996C15.092 2.493 14.027 2 12.847 2c-2.266 0-4.103 1.837-4.103 4.103 0 .322.036.635.106.935-3.41-.17-6.434-1.804-8.456-4.287-.353.607-.556 1.312-.556 2.064 0 1.424.724 2.679 1.825 3.415-.672-.021-1.305-.206-1.858-.514v.052c0 1.988 1.414 3.647 3.292 4.023-.344.095-.707.145-1.081.145-.264 0-.521-.026-.771-.074.523 1.632 2.038 2.816 3.833 2.851-1.404 1.1-3.174 1.757-5.096 1.757-.331 0-.658-.019-.98-.057 1.816 1.164 3.973 1.843 6.29 1.843 7.547 0 11.675-6.252 11.675-11.675 0-.178-.004-.355-.012-.531.802-.578 1.497-1.301 2.047-2.123z"/>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.page-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 40px 24px;
		line-height: 1.7;
		color: #1a1a1a;
	}

	.page-header {
		text-align: center;
		margin-bottom: 48px;
		padding-bottom: 24px;
		border-bottom: 2px solid rgba(0, 0, 0, 0.08);
	}

	.page-header h1 {
		font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
		font-size: clamp(32px, 5vw, 48px);
		font-weight: 900;
		letter-spacing: -0.03em;
		margin: 0 0 12px;
		color: #1a1a1a;
	}

	.page-subtitle {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 18px;
		color: #666;
		margin: 0;
		font-weight: 400;
	}

	.page-content {
		font-family: 'Crimson Text', 'Georgia', serif;
		font-size: 17px;
	}

	.page-content p {
		margin-bottom: 1.5rem;
	}

	.page-content a {
		color: #8b0000;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.page-content a:hover {
		color: #a52a2a;
	}

	.contact-grid {
		display: grid;
		gap: 48px;
		margin-bottom: 64px;
	}

	@media (min-width: 768px) {
		.contact-grid {
			grid-template-columns: 1fr 1.2fr;
		}
	}

	.contact-info h2,
	.contact-form-wrapper h2,
	.additional-info h2 {
		font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
		font-size: clamp(24px, 4vw, 32px);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 1.5rem;
		color: #1a1a1a;
	}

	.contact-details {
		font-style: normal;
		line-height: 1.8;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background: rgba(248, 248, 248, 0.5);
		border-left: 4px solid #8b0000;
		border-radius: 4px;
	}

	.contact-details strong {
		color: #1a1a1a;
	}

	.contact-sections {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.contact-section h3 {
		font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
		font-size: clamp(20px, 3.5vw, 24px);
		font-weight: 600;
		letter-spacing: -0.01em;
		margin: 0 0 0.75rem;
		color: #333;
	}

	.contact-section p {
		margin-bottom: 0;
	}

	.contact-form {
		background: rgba(248, 248, 248, 0.3);
		padding: 2rem;
		border-radius: 12px;
		border: 1px solid rgba(0, 0, 0, 0.06);
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	.form-group label {
		display: block;
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: #1a1a1a;
		margin-bottom: 0.5rem;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 12px 16px;
		border: 1px solid rgba(0, 0, 0, 0.14);
		border-radius: 8px;
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 16px;
		line-height: 1.5;
		color: #1a1a1a;
		background: white;
		transition: all 0.3s ease;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #8b0000;
		box-shadow: 0 0 0 3px rgba(139, 0, 0, 0.1);
	}

	.form-group textarea {
		resize: vertical;
		min-height: 120px;
	}

	.submit-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 14px 24px;
		background: #8b0000;
		color: white;
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		font-size: 16px;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.submit-btn:hover {
		background: #a52a2a;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(139, 0, 0, 0.3);
	}

	.additional-info {
		padding-top: 48px;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.additional-info h2 {
		margin-bottom: 1rem;
	}

	.social-links {
		display: flex;
		gap: 16px;
		margin-top: 1rem;
	}

	.social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: rgba(139, 0, 0, 0.1);
		color: #8b0000;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border: 1px solid rgba(139, 0, 0, 0.2);
	}

	.social-link:hover {
		background: #8b0000;
		color: white;
		transform: translateY(-2px);
	}

	.social-link svg {
		width: 20px;
		height: 20px;
	}

	@media (max-width: 768px) {
		.page-container {
			padding: 24px 16px;
		}

		.page-header {
			margin-bottom: 32px;
		}

		.page-header h1 {
			margin-bottom: 8px;
		}

		.page-content {
			font-size: 16px;
		}

		.contact-form {
			padding: 1.5rem;
		}

		.additional-info {
			padding-top: 32px;
		}
	}
</style>
